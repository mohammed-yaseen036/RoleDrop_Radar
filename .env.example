APP_ENV=development
APP_SECRET_KEY=replace-me-before-deploying
DATABASE_URL=sqlite:///./role_drop_radar.db
FRONTEND_URL=http://localhost:5173

# Configure these for Supabase-backed multi-user deployment.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Gemini is optional locally. When absent, deterministic matching is used.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
ENABLE_OLLAMA=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:latest

# Notifications remain logged as skipped until configured.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# Used by scheduled or manual monitor execution through the HTTP API.
MONITOR_API_KEY=
